NODE_ENV=production
PORT=3000
PUBLIC_URL=https://ob.edu.pl
ALLOWED_ORIGIN=https://ob.edu.pl
TRUST_PROXY=true

DATABASE_PATH=/data/attendance.sqlite3

MOODLE_BASE_URL=https://moodle2.e-wsb.pl
MOODLE_TOKEN=
MOODLE_TIMEOUT_MS=10000

ADMIN_PASSWORD=
AUTH_SECRET=
ADMIN_SESSION_SECONDS=28800
LOGIN_WINDOW_SECONDS=900
MAX_LOGIN_ATTEMPTS=5

MOODLE_PRESENT_STATUS_ACRONYM=P
MOODLE_ABSENT_STATUS_ACRONYM=A
MOODLE_TAKEN_BY_ID=
MOODLE_STATUS_SET=

COURSES_JSON=[{"course":"Statystyka","attendanceId":61195},{"course":"Psychologia społeczna","attendanceId":61234}]
OPEN_SECONDS=900
LOG_LEVEL=info
BACKUP_DIRECTORY=/backups
BACKUP_RETENTION_DAYS=14

# Google Sheets attendance — opcjonalne
# Folder może znajdować się na „Moim dysku” albo na Dysku współdzielonym.
# ID z adresu: https://drive.google.com/drive/folders/ID_FOLDERU
# Na Dysku współdzielonym konto serwisowe musi mieć dostęp z prawem edycji.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Klucz prywatny w jednej linii z literalnymi sekwencjami \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
TZ=Europe/Warsaw
