{
  "name": "obecnosc",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx scripts/migrate.ts",
    "inspect:moodle-statuses": "tsx scripts/inspect-moodle-statuses.ts",
    "backup:db": "tsx scripts/backup-db.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "better-sqlite3": "^13.0.1",
    "googleapis": "^173.0.0",
    "hono": "^4.12.31",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/qrcode": "^1.5.5",
    "eslint": "^9.39.1",
    "tsx": "^4.22.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
